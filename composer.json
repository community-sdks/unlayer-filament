{
    "name": "community-sdks/unlayer-filament",
    "description": "Filament wrapper for unlayer editor.",
    "keywords": [
        "Community SDKs",
        "laravel",
        "unlayer-filament"
    ],
    "homepage": "https://github.com/community-sdks/unlayer-filament",
    "support": {
        "issues": "https://github.com/community-sdks/unlayer-filament/issues",
        "source": "https://github.com/community-sdks/unlayer-filament"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "ZPMLabber",
            "email": "development@zpmlabs.com",
            "role": "Developer"
        }
    ],
    "require": {
        "community-sdks/unlayer-livewire": "^1.0",
        "php": "^8.3",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0",
        "zpmlabs/laravel-package-quick-demo": "^1.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "CommunitySdks\\UnlayerFilament\\Examples\\": "examples/",
            "CommunitySdks\\UnlayerFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CommunitySdks\\UnlayerFilament\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CommunitySdks\\UnlayerFilament\\UnlayerServiceProvider"
            ],
            "aliases": {
                "UnlayerFilament": "CommunitySdks\\UnlayerFilament\\Facades\\Unlayer"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
